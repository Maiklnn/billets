doctype html
html(lang="ru")


  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1, minimum-scale=1, shrink-to-fit=no')
    meta(name="description", content=siteDescription)
    meta(name='keywords', content='')
    title Блок1
    link(rel="stylesheet" href="assets/css/main.css?v=" + siteVersion)
    | <link rel="preconnect" href="https://fonts.googleapis.com">
    | <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    | <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,600;1,700&display=swap" rel="stylesheet">




  body

    - var class_name = 'advantages-list-slider'

    div(class=`${class_name} swiper-container`)
      div(class=`${class_name}__wrapper swiper-wrapper`)
        mixin item(img, title, descr)
          div(class=`${class_name}-slide swiper-slide`)
            div(class=`${class_name}-slide__title`)= title



        +item('assets/img/home/specification-slider/icon1.png', '1 слайд', 'Одна из наиболее динамично развихся компаний в сфере торговли')
        +item('assets/img/home/specification-slider/icon2.png', '2 слайд', 'Одна из наиболее динамично развихся компаний в сфере торговли')
        +item('assets/img/home/specification-slider/icon3.png', '3 слайд', 'Одна из наиболее динамично развихся компаний в сфере торговли')
        +item('assets/img/home/specification-slider/icon3.png', '4 слайд', 'Одна из наиболее динамично развихся компаний в сфере торговли')
        +item('assets/img/home/specification-slider/icon3.png', '5 слайд', 'Одна из наиболее динамично развихся компаний в сфере торговли')
        +item('assets/img/home/specification-slider/icon3.png', '6 слайд', 'Одна из наиболее динамично развихся компаний в сфере торговли')
        +item('assets/img/home/specification-slider/icon3.png', '7 слайд', 'Одна из наиболее динамично развихся компаний в сфере торговли')

      div(class=`${class_name}-pagination swiper-pagination`)

      div(class=`${class_name}-navigation`)
        div(class=`${class_name}-button-prev swiper-button-prev`)
        div(class=`${class_name}-button-next swiper-button-next`)

  script(src="assets/js/main.js?v=" + siteVersion)
